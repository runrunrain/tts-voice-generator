# TTS Voice Generator - Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# API keys can also be configured through the Settings page in the UI
# (stored encrypted in the database).

# OpenRouter API Key (required for TTS generation)
# Obtain from: https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY=

# OpenRouter API Base URL (optional, defaults to official endpoint)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Server listen port (default: 3001)
# PORT=3001

# Audio output directory (default: ./data/audio)
# AUDIO_OUTPUT_DIR=./data/audio

# SQLite database path (default: ./data/db/tts-generator.db)
# DB_PATH=./data/db/tts-generator.db

# Root data directory (default: ./data)
# DATA_DIR=./data

# Node environment (default: development)
# NODE_ENV=production
