{
  "name": "tts-voice-generator",
  "private": true,
  "version": "0.0.85",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "build": "vite build",
    "build:all": "npm run build && npm run server:build",
    "start:all": "npm run build:all && npm run server:start",
    "server:dev": "node server/node_modules/tsx/dist/cli.mjs watch server/src/index.ts",
    "server:build": "npm run build --prefix server",
    "server:start": "node server/dist/index.js",
    "server:test": "npm test --prefix server",
    "test": "npm test --prefix server",
    "package:release": "node scripts/package-release.js",
    "electron:build": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outdir=dist-electron --entry-names=[name] --out-extension:.js=.cjs",
    "desktop:target": "node scripts/build-desktop-target.js",
    "desktop:package:mac": "node scripts/build-desktop-target.js --platform darwin",
    "desktop:dist:mac:x64": "node scripts/build-desktop-target.js --platform darwin --arch x64",
    "desktop:dist:mac:arm64": "node scripts/build-desktop-target.js --platform darwin --arch arm64",
    "desktop:dist:win:x64": "node scripts/build-desktop-target.js --platform win32 --arch x64",
    "desktop:print-electron-version": "node -e \"console.log(require('electron/package.json').version)\"",
    "assert:desktop-audio-access": "node scripts/assert-desktop-audio-access.cjs",
    "deploy:current": "node scripts/quick-build-deploy.mjs",
    "quickstart": "node scripts/start.js",
    "smoke": "node scripts/start.js --smoke"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "electron-updater": "^6.6.2",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
