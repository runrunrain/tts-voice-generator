    "concurrently": "^9.2.1",
    "electron": "31.7.7",
    "electron-builder": "26.8.1",
    "esbuild": "0.28.0",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
